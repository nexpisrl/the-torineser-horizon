{%- doc -%}
  Decorazioni menu Torineser: pallini «Per Colore», icona mappa + badge «Nuovo» per «La Mappa».
  Handle menu: `per-colore`, `la-mappa`.

  @param {object} link - Voce menu (Navigation / linklists)
  @param {string} [part] - `before` (default): prima del titolo. `after`: dopo il titolo (solo La Mappa).
{%- enddoc -%}
{% liquid
  assign nav_part = part | default: 'before'
%}
{%- if nav_part == 'before' -%}
  {%- if link.handle == 'per-colore' -%}
    <span
      class="menu-link-per-colore-swatches"
      style="display:inline-flex;align-items:center;margin-inline-end:6px;"
      aria-hidden="true"
    >
      <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#B85C38;border:1.5px solid var(--color-background);box-sizing:border-box;flex-shrink:0;"></span>
      <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#1E3A5F;border:1.5px solid var(--color-background);margin-inline-start:-3px;box-sizing:border-box;flex-shrink:0;"></span>
      <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#C9A25A;border:1.5px solid var(--color-background);margin-inline-start:-3px;box-sizing:border-box;flex-shrink:0;"></span>
    </span>
  {%- endif -%}
  {%- if link.handle == 'la-mappa' -%}
    <span
      class="menu-link-la-mappa-icon"
      style="display:inline-flex;margin-inline-end:8px;flex-shrink:0;"
      aria-hidden="true"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="13"
        height="13"
        viewBox="0 0 14 14"
        fill="none"
        style="display:block;color:var(--color-primary);"
      >
        <path d="M1 3l4-1.5 4 1.5 4-1.5v9l-4 1.5-4-1.5-4 1.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
        <line x1="5" y1="1.5" x2="5" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line x1="9" y1="3" x2="9" y2="12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </span>
  {%- endif -%}
{%- elsif nav_part == 'after' -%}
  {%- if link.handle == 'la-mappa' -%}
    <span
      class="menu-link-la-mappa-badge"
      style="display:inline-flex;align-items:center;flex-shrink:0;background:var(--color-primary);color:#fff;font-size:8px;padding:2px 6px;border-radius:100px;letter-spacing:0.1em;text-transform:uppercase;font-weight:500;margin-inline-start:8px;line-height:1.2;"
    >
      Nuovo
    </span>
  {%- endif -%}
{%- endif -%}
