{% liquid
  assign col = block.settings.collection
  assign gap_px = block.settings.gap | default: 4
  case block.settings.aspect_ratio
    when 'portrait'
      assign quad_ratio = '4 / 5'
    when 'landscape'
      assign quad_ratio = '16 / 9'
    when 'adapt'
      assign quad_ratio = 1
      if col != blank and col.products_count > 0
        assign first_p = col.products.first
        if first_p.featured_media
          assign quad_ratio = 1 | divided_by: first_p.featured_media.aspect_ratio | times: first_p.featured_media.aspect_ratio
        endif
      endif
      comment
        adapt: usiamo 1 — il rapporto medio da 4 prodotti complica Liquid; manteniamo quadrato.
      endcomment
      assign quad_ratio = '1 / 1'
    else
      assign quad_ratio = '1 / 1'
  endcase
%}
{%- stylesheet -%}
  .collection-quad-gallery {
    width: 100%;
    aspect-ratio: var(--collection-quad-aspect-ratio, 1);
    position: relative;
    overflow: hidden;
  }

  .collection-quad-gallery__grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--collection-quad-gap, 4px);
  }

  .collection-quad-gallery__cell {
    min-height: 0;
    min-width: 0;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  }

  .collection-quad-gallery__cell--filled {
    background: transparent;
  }

  .collection-quad-gallery__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .collection-quad-gallery__placeholder {
    align-items: center;
    justify-content: center;
    padding: var(--padding-sm);
  }

  .collection-quad-gallery__placeholder svg {
    width: min(48px, 50%);
    height: auto;
    opacity: var(--opacity-40);
  }
{%- endstylesheet -%}
<div
  class="collection-quad-gallery spacing-style{% if block.settings.color_scheme %} color-{{ block.settings.color_scheme }}{% endif %}"
  style="
    {% render 'spacing-style', settings: block.settings %}
    --collection-quad-aspect-ratio: {{ quad_ratio }};
    --collection-quad-gap: {{ gap_px }}px;
    {% unless block.settings.color_scheme %}
      --color-background: rgba(var(--color-foreground-rgb) / var(--opacity-10));
    {% endunless %}
  "
  {{ block.shopify_attributes }}
>
  {% if col == blank %}
    <div
      class="collection-quad-gallery__grid"
      aria-hidden="true"
    >
      {% for _ in (1..4) %}
        <div class="collection-quad-gallery__cell collection-quad-gallery__placeholder flex flex-center">
          {{- 'detailed-apparel-1' | placeholder_svg_tag: 'collection-quad-gallery__svg' -}}
        </div>
      {% endfor %}
    </div>
  {% elsif col.products_count == 0 %}
    <div
      class="collection-quad-gallery__grid"
      aria-hidden="true"
    >
      {% for _ in (1..4) %}
        <div class="collection-quad-gallery__cell collection-quad-gallery__placeholder flex flex-center">
          {{- 'collection-apparel-1' | placeholder_svg_tag: 'collection-quad-gallery__svg' -}}
        </div>
      {% endfor %}
    </div>
  {% else %}
    {% liquid
      assign cell_count = 0
      assign widths_list = '200, 400, 600, 800, 1000'
      assign sizes_grid = '(min-width: 990px) 25vw, (min-width: 750px) 35vw, 50vw'
    %}
    <div class="collection-quad-gallery__grid">
      {% for product in col.products limit: 4 %}
        {% assign cell_count = cell_count | plus: 1 %}
        <div class="collection-quad-gallery__cell collection-quad-gallery__cell--filled">
          {% assign media = product.featured_media %}
          {% if media %}
            {{
              media
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                class: 'collection-quad-gallery__img',
                widths: widths_list,
                sizes: sizes_grid,
                alt: media.alt
              | default: product.title
            }}
          {% else %}
            <div class="collection-quad-gallery__placeholder flex flex-center" style="height: 100%">
              {{- 'product-apparel-1' | placeholder_svg_tag: 'collection-quad-gallery__svg' -}}
            </div>
          {% endif %}
        </div>
      {% endfor %}

      {% assign pad = 4 | minus: cell_count %}
      {% if pad > 0 %}
        {% for _ in (1..pad) %}
          <div
            class="collection-quad-gallery__cell"
            aria-hidden="true"
          ></div>
        {% endfor %}
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:names.collection_quad_gallery",
  "tag": null,
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "t:settings.spacing",
      "default": 4
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:settings.ratio",
      "options": [
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "square"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.background",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:spacing.padding_heading"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:spacing.padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:spacing.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:spacing.padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:spacing.padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
