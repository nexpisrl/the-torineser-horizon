{% layout none %}
{% comment %} Stesso page_size della sezione shop-by-color (loadAllPages sulle URL collezione). {% endcomment %}
{% paginate collection.products by 250 %}
[{% assign first = true %}
{% for product in collection.products %}
  {% capture pj %}
    {% render 'torineser-shop-color-product-json', product: product %}
  {% endcapture %}
  {% assign pj = pj | strip %}
  {% if pj != blank %}
    {% unless first %},{% endunless %}
    {{ pj }}
    {% assign first = false %}
  {% endif %}
{% endfor %}
]
{% endpaginate %}
